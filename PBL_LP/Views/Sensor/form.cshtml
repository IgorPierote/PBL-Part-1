@model SensorViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Cadastro de Sensor</h2>
<form action="Salvar" method="post">
    <input type="hidden" name="Operacao" value="@ViewBag.Operacao" />
    <label for="Codigo" class="control-label">Código</label>
    @if(ViewBag.Operacao=="I"){
        <input type="number" name="Codigo" value="@Model.Codigo" class="form-control"/>
    }
    else{
        <input type="number" name="Codigo" value="@Model.Codigo" class="form-control disabled" readonly />
    }
    <span asp-validation-for="Codigo" class="text-danger"></span>
    <br />

    <label for="Nome" class="control-label">Nome do Sensor</label>
    <input type="text" name="Nome" value="@Model.Nome" />
    <span asp-validation-for="Nome" class="text-danger"></span>
    <br />

    <label for="Tipo" class="control-label">Tipo</label>
    <select asp-for="Tipo" asp-items="ViewBag.Tipos" class="form-control"> </select>
    <span asp-validation-for="Tipo" class="text-danger"></span>
    <br />

    <label for="ValorDoAluguel" class="control-label">Valor do Aluguel</label>
    <input type="text" name="ValorDoAluguel" value="@Model.ValorDoAluguel" />
    <span asp-validation-for="ValorDoAluguel" class="text-danger"></span>
    <br />

    <input type="submit" value="Salvar dados" />
    <br />
</form>

